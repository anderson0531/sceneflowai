# ============================================================
# VERTEX AI (PRIMARY - ALL GOOGLE AI SERVICES)
# ============================================================
# SceneFlow uses Vertex AI for all Google AI services:
# - LLM: Gemini 2.5 Flash (text generation, JSON responses)
# - Image Generation: Imagen 4.0 (thumbnails, billboards, character images)
# - Video Generation: Veo 3.1 via predictLongRunning (default 8s clips, safetySetting, personGeneration)
#   Gemini Omni Flash preview is opt-in only: explicit 10s duration or EXT with interaction: refs
# - Vision Analysis: Gemini with vision (character consistency, image validation)
#
# Set up a service account with Vertex AI permissions:
# - Vertex AI User (roles/aiplatform.user)
# - Service Usage Consumer (roles/serviceusage.serviceUsageConsumer)
#
VERTEX_PROJECT_ID=your_gcp_project_id_here
VERTEX_LOCATION=us-central1
# Service account JSON key (base64 encoded for Vercel, or JSON string)
GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Alternative: Path to service account key file (for local development)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account.json

# ============================================================
# VERTEX AI SAFETY SETTINGS (REDUCE GUARDRAIL RESTRICTIONS)
# ============================================================
# Configure safety thresholds to reduce overly restrictive filtering
# for professional film production content. Unlike consumer Gemini,
# Vertex AI allows customizing these per application.
#
# Gemini (text/vision) safety threshold:
# - BLOCK_NONE: No blocking (enterprise/regional restrictions may apply)
# - BLOCK_ONLY_HIGH: Only block high probability harmful content (recommended)
# - BLOCK_MEDIUM_AND_ABOVE: Block medium and high (moderate)
# - BLOCK_LOW_AND_ABOVE: Block all (strictest)
VERTEX_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH
#
# Imagen safety filter level for image generation:
# - block_few: Least restrictive (recommended for creative content)
# - block_some: Moderate filtering
# - block_most: Strict filtering
IMAGEN_SAFETY_FILTER_LEVEL=block_few
#
# Imagen person generation setting:
# - allow_all: Allow all person generation including public figures
# - allow_adult: Allow adult person generation (default)
# - dont_allow: Disable person generation
IMAGEN_PERSON_GENERATION=allow_adult
#
# Veo video safety setting (Vertex parameters.safetySetting — default path for REF/I2V/FTV/T2V ≤8s):
# - block_only_high: Recommended default; blocks mainly high-probability harm (medium often passes)
# - block_none: Most permissive where allowed (enterprise/regional policy may still apply)
# - block_few / block_some / block_most: progressively stricter
VEO_SAFETY_SETTING=block_only_high
#
# Include Responsible AI filter reasons / categories in Veo responses (parameters.includeRaiReason).
# Default on (omit or true). Set to false only if you must minimize response size.
# VEO_INCLUDE_RAI_REASON=true
#
# Omni video (Interactions API) — opt-in only (explicit 10s clip or EXT interaction: continuation):
# Not used for default fast/premium tiers; Veo 3.1 predictLongRunning is the default video path.
# Omni video (Interactions API) safety_settings threshold (Gemini harm categories):
# - BLOCK_ONLY_HIGH: Recommended default for cinematic content
# - BLOCK_MEDIUM_AND_ABOVE: Moderate
# OMNI_VIDEO_SAFETY_THRESHOLD=BLOCK_ONLY_HIGH
#
# Send explicit safety_settings on Omni Interactions requests (default on).
# Set to false if the preview endpoint rejects the field.
# OMNI_VIDEO_SAFETY_SETTINGS_ENABLED=true

# ============================================================
# SCALABLE PRODUCTION VIDEO CONFIGURATION
# ============================================================
# For high-volume production, configure multiple regions and projects
# to distribute quota and provide automatic failover.
#
# Multi-region support (comma-separated, Veo available in us-central1)
# VEO_REGIONS=us-central1
#
# Multi-project quota distribution (comma-separated project IDs)
# Service account must have access to all listed projects
# VERTEX_PROJECT_IDS=project-1,project-2,project-3
#
# Fallback to Gemini API when all Vertex AI endpoints are exhausted
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_API_KEY_BACKUP=your_backup_gemini_api_key_here

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
DB_NAME=sceneflow_ai

# JWT Secret for Authentication
JWT_SECRET=your_jwt_secret_here

# NextAuth session encryption (required in production for secure sessions)
NEXTAUTH_SECRET=your_nextauth_secret_here
# Legacy alias still supported:
# NEXT_AUTH_SECRET=your_nextauth_secret_here

# Encryption Key for BYOK Credentials
ENCRYPTION_KEY=your_32_character_encryption_key_here

# Vercel Environment (for production)
VERCEL_ENV=production

# Google Cloud SQL (production — preferred over Supabase/Neon)
CLOUD_SQL_INSTANCE_CONNECTION_NAME=sceneflowai-2d3e6:us-central1:sceneflow-db
DB_USER=sceneflow_app
DB_PASSWORD=your_db_password
DB_NAME=sceneflow

# Legacy direct Postgres URL (local dev fallback)
# DATABASE_URL=postgresql://username:password@localhost:5432/sceneflow

# [DEPRECATED] Google Gemini API Studio
# No longer used - migrated to Vertex AI for higher quotas and production reliability
# GEMINI_API_KEY=your_gemini_api_key_here

# [DEPRECATED] Google Cloud Storage (GCS)
# No longer required - migrated to Vercel Blob storage
# GCS_BUCKET_NAME=your-bucket-name

# ============================================================
# ELEVENLABS (SOUND EFFECTS & OPTIONAL TTS)
# ============================================================
# Used for SFX generation. TTS primarily uses Google.
# Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Blueprint share narration uses bracket tags — requires eleven_v3 (not multilingual_v2).
# ELEVENLABS_STORYTELLING_MODEL=eleven_v3

# Optional: LLM for Cue
# Get a key at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Shotstack (Video Editing & Rendering)
# Get a key at https://shotstack.io
SHOTSTACK_API_KEY=your_shotstack_api_key_here
SHOTSTACK_API_URL=https://api.shotstack.io/stage

# Whop (Payment Processing - Merchant of Record)
# Setup: https://sandbox.whop.com (sandbox) or https://whop.com (production)
# 1. Create company under Life Focus, LLC
# 2. Developer → API keys → Company API key
# 3. Create plans for explorer ($9 one-time), starter/pro/studio (monthly renewal)
# 4. Developer → Webhooks → POST https://<your-domain>/api/webhooks/whop
#    Subscribe to: payment.succeeded, payment.failed, membership.went_valid,
#    membership.went_invalid, refund.created
WHOP_API_KEY=your_whop_api_key_here
WHOP_COMPANY_ID=biz_xxxxxxxxxxxxx
WHOP_WEBHOOK_SECRET=your_webhook_secret_here
WHOP_PLAN_EXPLORER=plan_xxxxxxxxxxxxx
WHOP_PLAN_STARTER=plan_xxxxxxxxxxxxx
WHOP_PLAN_PRO=plan_xxxxxxxxxxxxx
WHOP_PLAN_STUDIO=plan_xxxxxxxxxxxxx
WHOP_PLAN_ENTERPRISE=plan_xxxxxxxxxxxxx
WHOP_CHECKOUT_RETURN_URL=https://your-domain.com/dashboard/settings/billing
PAYMENT_PROVIDER=whop

# Demo checkout: grants credits immediately when Whop env is missing (local only).
# Set DEMO_MODE=true only when WHOP_API_KEY is not configured.
# When Whop keys ARE set, real Whop embed + webhooks are used even in development.
DEMO_MODE=false
# Force real Whop checkout in development (skip demo auto-grant when keys missing fails)
# FORCE_WHOP_CHECKOUT=true

# Cron auth for /api/cron/* routes (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=your_cron_secret_here

# Production cutover checklist (after sandbox E2E):
# 1. Create production Whop plans → update WHOP_PLAN_* IDs
# 2. Set WHOP_WEBHOOK_SECRET + webhook URL https://<domain>/api/webhooks/whop
# 3. Set WHOP_CHECKOUT_RETURN_URL to production billing URL
# 4. Rotate WHOP_API_KEY if previously exposed
# 5. Run POST /api/setup/migrate-whop-payment on production DB

# Legacy Paddle (deprecated — kept for migration reference only)
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=

# Extended moderation & content validation (Studio validation API + Kling guard when configured)
# Get keys at https://thehive.ai
HIVE_AI_ACCESS_KEY_ID=your_hive_access_key_id_here
HIVE_AI_SECRET_KEY=your_hive_secret_key_here
# Enables Studio content validation API (same credit model as other Studio tools)
HIVE_MODERATION_ENABLED=true
# KLING_HIVE_GUARD_ENABLED=true — pre-storage review on Extended Creative Services fallback path

# =============================================================================
# KLING DIRECT API (primary video provider)
# =============================================================================
# KLING_API_KEY=your-kling-api-key
# KLING_ACCESS_KEY=your-access-key
# KLING_SECRET_KEY=your-secret-key
# KLING_API_BASE_URL=https://api.klingai.com/v1
# KLING_DEFAULT_MODEL=kling-v3-omni
# KLING_DEFAULT_QUALITY=pro
# KLING_PRIMARY_ENABLED=true
# KLING_SOUND_ENABLED=true
# KLING_ASYNC=false  # Required true for long-take pipeline (webhook-driven extend/stitch/lipsync)
# KLING_WEBHOOK_SECRET=your-webhook-secret
# KLING_WEBHOOK_BASE_URL=https://your-app.vercel.app
# KLING_WATERMARK_DEFAULT=false
# KLING_POLL_INTERVAL_MS=5000
# KLING_POLL_TIMEOUT_SEC=300
# KLING_VEO_FALLBACK_ENABLED=true
# ASSET_PROVENANCE_SECRET= — HMAC key for segment video provenance records
# C2PA_SIGNING_ENABLED=false — async in-file credentials embedding when enabled

# ============================================================
# CLOUD RUN FFmpeg RENDERER (Scene Video Export)
# ============================================================
# Configuration for the Cloud Run Job that renders final scene videos
# by concatenating segment MP4s with audio tracks.
#
# GCP Project ID (same as VERTEX_PROJECT_ID in most setups)
GCP_PROJECT_ID=your_gcp_project_id_here
#
# Cloud Run region (should match VERTEX_LOCATION for latency)
GCP_REGION=us-central1
#
# Cloud Run Job name (created by deploy-ffmpeg-renderer.sh script)
CLOUD_RUN_JOB_NAME=sceneflow-ffmpeg-renderer
#
# GCS bucket for render job specs and outputs
# Create with: gsutil mb -l us-central1 gs://your-render-bucket
GCS_RENDER_BUCKET=sceneflow-render-jobs

# Observability
METRICS_AUTH_TOKEN=
LOG_LEVEL=info

# Test Mode Features
# Enable test plan switching in production (for QA/testing before Whop go-live)
ENABLE_TEST_PLAN_SWITCH=false

# Vercel Blob Storage (for image uploads and blueprint collaboration section MP3s)
# Blueprint share links need ELEVENLABS_API_KEY + BLOB_READ_WRITE_TOKEN to cache narration audio.
# Automatically configured on Vercel. For local dev:
# BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
# PEXELS_API_KEY=your_pexels_api_key_here
# Private Blob store for EAP OTP, applications, and reviewer OTP (access: private)
# BLOB_PRIVATE_READ_WRITE_TOKEN=your_private_vercel_blob_token_here

# ============================================================
# RESEND (EAP + transactional email)
# ============================================================
# Domain sfai.studio must be verified in Resend before sending.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=SceneFlow AI Studio <noreply@sfai.studio>
